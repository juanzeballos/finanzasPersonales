# Copiá este archivo a ".env" en la VM y completá los valores reales.
# El .env NO se sube al repo (está en .gitignore). Cargá las variables ahí.

# Dominio (DuckDNS gratis o uno propio) — Caddy saca el HTTPS para este nombre.
DOMINIO=misgastos.duckdns.org

# Contraseña de la base Postgres (poné una larga y aleatoria).
POSTGRES_PASSWORD=cambiame-por-una-clave-fuerte

# Proveedor de IA y su key (Groq es gratis).
GROQ_API_KEY=gsk_tu_key_de_groq

# Clave para firmar los tokens de sesión. Generá una con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambiame-por-una-clave-larga-y-aleatoria
